# Alpha Vantage API Key (get one free at https://www.alphavantage.co/support/#api-key)
NEXT_PUBLIC_ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Optional: OpenAI API Key for AI features
OPENAI_API_KEY=your_openai_key_here

# Authentication (required for login)
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me_to_a_strong_password
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Optional: Supabase (for cross-device sync)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
